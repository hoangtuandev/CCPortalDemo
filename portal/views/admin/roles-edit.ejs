<%- include('layout', { pageTitle: 'Sửa vai trò', activePage: 'roles', username }) %>

<div class="page-header">
  <h1>Sửa vai trò</h1>
  <a href="/admin/roles" class="btn btn-secondary btn-sm">← Danh sách</a>
</div>

<% if (success) { %>
<div class="alert alert-success"><%= success %></div>
<% } %>
<% if (error) { %>
<div class="alert alert-error"><%= error %></div>
<% } %>

<%
  const val = {
    display_name: form ? form.display_name : role.display_name,
    description:  form ? form.description  : (role.description ?? ''),
    is_admin:     form != null ? form.is_admin : role.is_admin,
  };
%>

<form method="post" action="/admin/roles/<%= role.id %>" class="admin-form">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">

  <div class="form-group">
    <label class="form-label">Mã vai trò</label>
    <input class="form-control font-mono" type="text" value="<%= role.name %>" disabled
           style="background:var(--c-bg);color:var(--c-text-muted)">
    <p class="form-hint">Mã vai trò không thể thay đổi sau khi tạo.</p>
  </div>

  <div class="form-group">
    <label class="form-label">Tên hiển thị <span class="req">*</span></label>
    <input class="form-control" type="text" name="display_name" value="<%= val.display_name %>" required>
  </div>

  <div class="form-group">
    <label class="form-label">Mô tả <span class="text-muted" style="font-weight:400">(tùy chọn)</span></label>
    <textarea class="form-control" name="description" rows="2"
              placeholder="Mô tả ngắn về vai trò này"><%= val.description %></textarea>
  </div>

  <div class="form-group" style="margin-bottom:1.75rem">
    <label class="checkbox-label">
      <input type="checkbox" name="is_admin" value="1" <%= val.is_admin ? 'checked' : '' %>>
      <span>Vai trò có quyền quản trị (admin)</span>
    </label>
    <p class="form-hint" style="margin-left:1.5rem">Admin có thể truy cập khu vực quản trị, quản lý tài khoản và vai trò.</p>
  </div>

  <div style="display:flex;gap:.75rem">
    <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
    <a href="/admin/roles" class="btn btn-secondary">Hủy</a>
  </div>
</form>

<% if (userCount === 0) { %>
<hr class="section-sep-danger">
<div class="danger-zone">
  <h2>Xóa vai trò</h2>
  <p class="form-hint" style="margin-bottom:1rem">
    Vai trò này chưa có tài khoản nào. Xóa là hành động <strong>không thể hoàn tác</strong>.
  </p>
  <form method="post" action="/admin/roles/<%= role.id %>/delete">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <button type="submit" class="btn btn-danger"
            onclick="return confirm('Xác nhận xóa vai trò \'<%= role.name %>\'?')">
      Xóa vai trò này
    </button>
  </form>
</div>
<% } else { %>
<hr class="section-sep">
<div class="danger-zone">
  <h2 style="color:var(--c-text-muted)">Xóa vai trò</h2>
  <p class="form-hint">
    Không thể xóa: vai trò này còn <strong><%= userCount %> tài khoản</strong>.
    Hãy chuyển tất cả tài khoản sang vai trò khác trước.
  </p>
</div>
<% } %>

<%- include('_foot') %>
